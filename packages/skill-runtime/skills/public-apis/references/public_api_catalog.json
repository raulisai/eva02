    {
      "id": "open-meteo-forecast",
      "name": "Open-Meteo Forecast",
      "category": "weather",
      "description": "Daily and hourly weather forecast by latitude/longitude.",
      "docs_url": "https://open-meteo.com/en/docs",
      "auth": "none",
      "risk": "low",
      "rate_limit": "Fair use; cache repeated location/date lookups.",
      "endpoints": [
        {
          "id": "forecast.daily",
          "method": "GET",
          "url_template": "https://api.open-meteo.com/v1/forecast?latitude={latitude}&longitude={longitude}&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max,wind_speed_10m_max&timezone=auto&forecast_days={days}",
          "sample_url": "https://api.open-meteo.com/v1/forecast?latitude=19.4326&longitude=-99.1332&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max,wind_speed_10m_max&timezone=auto&forecast_days=1",
          "params": { "latitude": "19.4326", "longitude": "-99.1332", "days": "1" },
          "use_for": ["weather", "forecast", "planning_by_weather"]
        }
      ]
    },
