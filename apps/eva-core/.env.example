# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# Database (direct connection for migrations/admin)
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3000
NODE_ENV=development
BROWSER_HEADLESS=false
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Comma-separated list of allowed dashboard origins (NEVER '*')
CORS_ORIGIN=http://localhost:3001

# Secrets at rest (AES-256-GCM master key for org integration tokens)
# Generate with: openssl rand -hex 32
EVA_SECRETS_KEY=

# Public base URL used to register channel webhooks (e.g. Telegram setWebhook)
PUBLIC_WEBHOOK_URL=

# Legacy single-tenant fallbacks (prefer per-org tokens via /integrations)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
